generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  username     String           @unique
  password     String
  role                   String           @default("INVESTOR")
  reset_password_token   String?
  reset_password_expires DateTime?
  created_at             DateTime         @default(now())
  updated_at             DateTime         @updatedAt
  activityLogs           ActivityLog[]
  profile                InvestorProfile?
}

model InvestorProfile {
  id                           String         @id @default(uuid())
  user_id                      String?        @unique
  first_name                   String
  middle_name                  String?
  last_name                    String
  full_name                    String
  gender                       String?
  dob                          DateTime?
  age                          Int?
  profile_photo_url            String?
  investor_type                String?        @default("Individual")
  marital_status               String?
  father_name                  String?
  spouse_name                  String?
  email                        String         @unique
  alt_email                    String?
  phone                        String
  alt_phone                    String?
  whatsapp_number              String?
  pref_communication           String?        @default("Phone")
  best_time_to_contact         String?        @default("Anytime")
  address_line1                String
  address_line2                String?
  landmark                     String?
  village                      String?
  mandal                       String?
  district                     String?
  state                        String
  country                      String
  pincode                      String?
  address_type                 String?        @default("Permanent")
  same_as_permanent            Boolean        @default(true)
  current_address_line1        String?
  current_village              String?
  current_district             String?
  current_state                String?
  current_country              String?
  current_pincode              String?
  occupation                   String?
  job_title                    String?
  company_name                 String?
  company_type                 String?
  industry                     String?
  work_experience              String?
  monthly_income               String?
  annual_income                String?
  pan_number                   String?
  gst_number                   String?
  company_address              String?
  investment_interest          String?
  budget_range                 String?
  investment_purpose           String?
  investment_source            String?
  holding_period               String?
  risk_preference              String?
  expected_return_notes        String?
  lead_source                  String?
  assigned_advisor             String?
  nominee_name                 String?
  nominee_relation             String?
  nominee_phone                String?
  nominee_email                String?
  nominee_aadhaar              String?
  nominee_address              String?
  nominee_id_url               String?
  passbook_photo_url           String?
  land_document_url            String?
  payment_proof_url            String?
  aadhaar_url                  String?
  pan_url                      String?
  agreement_url                String?
  nominee_document_url         String?
  passbook_verification_status String?        @default("Pending")
  send_welcome_email           Boolean        @default(true)
  send_whatsapp                Boolean        @default(true)
  send_sms                     Boolean        @default(true)
  monthly_updates              Boolean        @default(true)
  payment_reminders            Boolean        @default(true)
  document_updates             Boolean        @default(true)
  follow_up_date               DateTime?
  follow_up_status             String?
  priority                     String?        @default("Medium")
  assigned_employee            String?
  created_by                   String?
  last_updated_by              String?
  id_type                      String?
  id_number                    String?
  status                       String         @default("PENDING")
  notes                        String?
  created_at                   DateTime       @default(now())
  updated_at                   DateTime       @updatedAt
  documents                    Document[]
  investments                  Investment[]
  user                         User?          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  landPlots                    LandPlot[]
  media                        Media[]
  notifications                Notification[]
  payments                     Payment[]
}

model LandPlot {
  id                 String             @id @default(uuid())
  investor_id        String?
  title              String
  description        String
  location           String
  district           String
  state              String
  survey_number      String
  total_area         Float
  unit               String             @default("Acres")
  latitude           Float?
  longitude          Float?
  purchase_date      DateTime?
  purchase_price     Float
  current_value      Float
  status             String             @default("AVAILABLE")
  images             String             @default("")
  documents          String             @default("")
  passbook_number    String?            @unique
  plot_size          String?
  plot_configuration String?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  crops              Crop[]
  documentRecords    Document[]
  investments        Investment[]
  investor           InvestorProfile?   @relation(fields: [investor_id], references: [id])
  mediaRecords       Media[]
  plantationUpdates  PlantationUpdate[]
}

model Crop {
  id                    String             @id @default(uuid())
  land_id               String
  name                  String             @default("Sandalwood")
  variety               String
  planted_date          DateTime?
  total_plants          Int
  surviving_plants      Int
  growth_stage          String             @default("SEEDLING")
  expected_harvest_date DateTime?
  height_avg            Float              @default(0.0)
  health_status         String             @default("GOOD")
  notes                 String?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  land                  LandPlot           @relation(fields: [land_id], references: [id], onDelete: Cascade)
  plantationUpdates     PlantationUpdate[]
}

model PlantationUpdate {
  id          String    @id @default(uuid())
  crop_id     String?
  land_id     String?
  update_type String
  title       String
  description String
  images      String    @default("")
  recorded_by String?
  update_date DateTime  @default(now())
  created_at  DateTime  @default(now())
  crop        Crop?     @relation(fields: [crop_id], references: [id])
  land        LandPlot? @relation(fields: [land_id], references: [id])
}

model Investment {
  id               String          @id @default(uuid())
  investor_id      String
  land_id          String?
  investment_type  String
  amount           Float
  currency         String          @default("INR")
  investment_date  DateTime        @default(now())
  maturity_date    DateTime?
  expected_returns Float
  roi_percentage   Float
  status           String          @default("PENDING")
  contract_number  String
  notes            String?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  investor         InvestorProfile @relation(fields: [investor_id], references: [id], onDelete: Cascade)
  land             LandPlot?       @relation(fields: [land_id], references: [id])
  payments         Payment[]
}

model Payment {
  id             String          @id @default(uuid())
  investment_id  String?
  investor_id    String
  amount         Float
  currency       String          @default("INR")
  payment_type   String
  payment_method String
  transaction_id String
  payment_date   DateTime        @default(now())
  status         String          @default("PENDING")
  receipt_url    String?
  notes          String?
  created_at     DateTime        @default(now())
  investment     Investment?     @relation(fields: [investment_id], references: [id])
  investor       InvestorProfile @relation(fields: [investor_id], references: [id], onDelete: Cascade)
}

model Document {
  id          String          @id @default(uuid())
  investor_id String
  land_id     String?
  title       String
  description String?
  file_url    String
  file_type   String
  file_size   Int
  category    String
  is_public   Boolean         @default(false)
  created_at  DateTime        @default(now())
  investor    InvestorProfile @relation(fields: [investor_id], references: [id], onDelete: Cascade)
  land        LandPlot?       @relation(fields: [land_id], references: [id])
}

model Media {
  id          String          @id @default(uuid())
  investor_id String?
  land_id     String?
  title       String
  description String?
  file_url    String
  file_type   String
  category    String
  created_at  DateTime        @default(now())
  investor    InvestorProfile? @relation(fields: [investor_id], references: [id], onDelete: Cascade)
  land        LandPlot?        @relation(fields: [land_id], references: [id])
}

model Inquiry {
  id                  String   @id @default(uuid())
  full_name           String
  email               String
  phone               String
  investment_interest String
  budget_range        String
  plot_size           String
  message             String
  status              String   @default("NEW")
  admin_notes         String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}

model Notification {
  id           String           @id @default(uuid())
  recipient_id String
  investor_id  String?
  title        String
  message      String
  type         String           @default("INFO")
  is_read      Boolean          @default(false)
  link         String?
  created_at   DateTime         @default(now())
  investor     InvestorProfile? @relation(fields: [investor_id], references: [id], onDelete: Cascade)
}

model Testimonial {
  id         String   @id @default(uuid())
  name       String
  location   String
  investment String?
  text       String
  rating     Int      @default(5)
  image_url  String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
}

model GalleryItem {
  id          String   @id @default(uuid())
  title       String
  category    String
  type        String   @default("image")
  image_url   String?
  description String?
  created_at  DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(uuid())
  user_id    String?
  action     String
  details    String?
  ip_address String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])
}

model Faq {
  id         String   @id @default(uuid())
  question   String
  answer     String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
}

model SiteContent {
  id         String   @id @default(uuid())
  section    String
  key        String   @unique
  value      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model MarketPrice {
  id           String   @id @default(uuid())
  market_price Float
  grade        String
  unit         String
  source       String
  last_updated DateTime
  verified     Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}
